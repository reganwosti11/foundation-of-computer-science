<mxfile host="app.diagrams.net">
  <diagram name="Vertical HTTPS Basic Auth Flow">
    <mxGraphModel dx="800" dy="1400" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="2" value="User Browser" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="40" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="3" value="Username:Password" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="140" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="4" value="Base64 Encoding" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="240" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="5" value="HTTPS Request (Authorization Header)" style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="250" y="340" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="6" value="TLS Encryption (Transport)" style="rounded=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="250" y="440" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="7" value="Web Server → TLS Decrypt → Base64 Decode → Verify" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="540" width="300" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell edge="1" parent="1" source="2" target="3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" parent="1" source="3" target="4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" parent="1" source="4" target="5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" parent="1" source="5" target="6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" parent="1" source="6" target="7"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>