<mxfile host="app.diagrams.net">
  <diagram name="Vertical Email Base64 TLS Flow">
    <mxGraphModel dx="800" dy="1400" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="2" value="Sender Email Client" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="40" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="3" value="Binary Attachment (PDF/Image)" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="140" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="4" value="MIME + Base64 Encoding" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="240" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="5" value="SMTP + STARTTLS" style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="250" y="340" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="6" value="TLS Encryption (Transport Layer)" style="rounded=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="250" y="440" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="7" value="Receiving Mail Server" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="540" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="8" value="TLS Decryption → Base64 Decoding → Attachment Delivered" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="640" width="300" height="80" as="geometry"/>
        </mxCell>

        <!-- Vertical Arrows -->
        <mxCell edge="1" parent="1" source="2" target="3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" parent="1" source="3" target="4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" parent="1" source="4" target="5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" parent="1" source="5" target="6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" parent="1" source="6" target="7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell edge="1" parent="1" source="7" target="8"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>